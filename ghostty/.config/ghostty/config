# Font — JetBrains Mono, chosen after an audition for its tall x-height and
# sturdy weight (far less eye-strain than CommitMono for all-day reading).
font-family = JetBrainsMono Nerd Font Mono
font-size = 11.5

# Linux/FreeType only: disable light hinting (on by default in 1.3+) so glyph
# stems render heavier — closest match to kitty's bolder text rendering, since
# font-thicken is macOS-only. If still too light, use `font-style = Bold`.
freetype-load-flags = no-light

# Theme - Rosé Pine Moon (OneDark BG)
background = #282c34
foreground = #e0def4

selection-foreground = #e0def4
selection-background = #3b4252

cursor-color = #e0def4
cursor-text = #282c34

# Color palette
palette = 0=#1b1f27
palette = 1=#eb6f92
palette = 2=#3e8fb0
palette = 3=#f6c177
palette = 4=#9ccfd8
palette = 5=#c4a7e7
palette = 6=#ea9a97
palette = 7=#e0def4
palette = 8=#6e6a86
palette = 9=#eb6f92
palette = 10=#3e8fb0
palette = 11=#f6c177
palette = 12=#9ccfd8
palette = 13=#c4a7e7
palette = 14=#ea9a97
palette = 15=#e0def4

# Window
window-padding-x = 4
window-padding-y = 4

# Line height — extra cell height reduces line-tracking effort when reading
# dense markdown/diffs all day.
adjust-cell-height = 10

# Shell integration
shell-integration = detect

# Don't prompt to confirm closing a surface/window
confirm-close-surface = false

# macOS cmd key mappings
keybind = super+j=text:\x1bj
keybind = super+k=text:\x1bk
keybind = super+l=text:\x1bl
keybind = super+semicolon=text:\x1b;

# Mouse
link-url = true
