#!/usr/bin/env bash
# log-escape — append one JSONL line per escaped defect to the escape log.
#
# An "escape" is a defect found DOWNSTREAM of the gate that should have caught
# it: a human PR read, a /cc comment, a /refactor smell sweep, a /q-verify gap,
# or production. This file is the ground-truth side of the review flywheel;
# ~/.claude/review-metrics.jsonl is the "what the gates caught" side. /review-stats
# aggregates both to compute per-gate escape rates.
#
# usage: log-escape key=value [key=value ...]
#   canonical fields:
#     repo=<basename>
#     stage_found=cc|refactor|q-verify|verify|pr-human|prod|other
#     gate_missed=review|drift-gate|test-intent|coder|q-verify
#     class=bug|smell|duplication|plan-drift|test-gap|other
#     severity=high|medium|low
#     desc="one line"
#     file=path
#
# Numeric-looking values are stored as numbers, everything else as strings.
# A "date" field (UTC ISO 8601) is always added. Output file:
#   $REVIEW_ESCAPES_FILE or ~/.claude/review-escapes.jsonl
set -euo pipefail

command -v jq >/dev/null || { echo "jq is required" >&2; exit 1; }
out="${REVIEW_ESCAPES_FILE:-$HOME/.claude/review-escapes.jsonl}"

json=$(jq -cn '{date: (now | todate)}')
for kv in "$@"; do
  case "$kv" in
    *=*) ;;
    *) echo "skipping malformed arg (want key=value): $kv" >&2; continue ;;
  esac
  k="${kv%%=*}"
  v="${kv#*=}"
  json=$(jq -c --arg k "$k" --arg v "$v" '.[$k] = ($v | (tonumber? // .))' <<< "$json")
done

printf '%s\n' "$json" >> "$out"
echo "logged → $out"
