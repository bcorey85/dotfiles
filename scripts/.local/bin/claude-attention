#!/usr/bin/env bash
# claude-attention — agent attention router.
#
# Turns the hook-stamped session states (@claude_state, written by
# tmux-claude-session-manager's state.sh) from pull into push: a desktop
# notification the moment a session needs input, and a status-right badge
# counting sessions that want attention — no more polling the C-/ picker.
#
# ping <state> [message]   Hook entry point (see ~/.claude/settings.json).
#                          Stamps <state> via state.sh, force-refreshes every
#                          client's status line, then notifies through
#                          ~/.claude/scripts/notify — UNLESS the session is
#                          already on-screen (the active session of some
#                          attached client, incl. the agent popup's nested
#                          client), where a toast would just be noise.
#                          Outside tmux it degrades to a plain notification.
# badge                    Status-right fragment (wired into the theme confs):
#                          yellow ● N = sessions waiting for input (any
#                          session), green ● N = idle agent-prefixed sessions
#                          (finished, ready to harvest). Empty when neither.
set -u

STATE_SH="$HOME/.tmux/plugins/tmux-claude-session-manager/scripts/state.sh"
NOTIFY="$HOME/.claude/scripts/notify"

case "${1:-}" in

ping)
  state="${2:-waiting}"
  msg="${3:-needs your attention}"
  if [ -n "${TMUX_PANE:-}" ]; then
    session=$(tmux display-message -p -t "$TMUX_PANE" '#{session_name}' 2>/dev/null || true)
    [ -x "$STATE_SH" ] && "$STATE_SH" "$state"
    tmux list-clients -F '#{client_name}' 2>/dev/null | while IFS= read -r c; do
      tmux refresh-client -S -t "$c" 2>/dev/null
    done
    # On-screen already? Then the badge is enough — skip the toast.
    if [ -n "$session" ] &&
      tmux list-clients -F '#{session_name}' 2>/dev/null | grep -qx "$session"; then
      exit 0
    fi
  fi
  [ -x "$NOTIFY" ] && "$NOTIFY" 'Claude Code' "$msg"
  exit 0
  ;;

badge)
  command -v tmux >/dev/null 2>&1 || exit 0
  prefix=$(tmux show-option -gqv @claude_session_prefix 2>/dev/null)
  prefix=${prefix:-claude-}
  waiting=0 idle=0
  while IFS= read -r s; do
    st=$(tmux show-options -qv -t "$s" @claude_state 2>/dev/null)
    case "$st" in
    waiting) waiting=$((waiting + 1)) ;;
    # idle is only signal on agent sessions (finished, ready to harvest);
    # on regular sessions it's just the residue of the last conversation.
    idle) [ "${s#"$prefix"}" != "$s" ] && idle=$((idle + 1)) ;;
    esac
  done < <(tmux list-sessions -F '#{session_name}' 2>/dev/null)

  [ "$waiting" -eq 0 ] && [ "$idle" -eq 0 ] && exit 0

  # Palette follows the theme state file (same source as tmux/nvim/emacs).
  if [ "$(cat "$HOME/.cache/theme-mode" 2>/dev/null)" = "light" ]; then
    wait_style='#[bg=#9a6700,fg=#ffffff,bold]' idle_style='#[fg=#116329,bold]'
  else
    wait_style='#[bg=#daaa3f,fg=#22272e,bold]' idle_style='#[fg=#57ab5a,bold]'
  fi
  out=""
  [ "$waiting" -gt 0 ] && out="${wait_style} ● ${waiting} #[default] "
  [ "$idle" -gt 0 ] && out="${out}${idle_style}● ${idle}#[default] "
  printf '%s' "$out"
  ;;

*)
  echo "usage: claude-attention ping <state> [message] | badge" >&2
  exit 2
  ;;
esac
