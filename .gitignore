*.log
*.local.yml
nvim/.config/nvim/lazy-lock.json

# Machine-specific hyprland config (created by install/hyprland)
hypr/.config/hypr/hyprland.local.conf

# Machine-specific kitty overrides (e.g. macOS font_size)
kitty/.config/kitty/local.conf

# === Claude Code (claude/.claude/) ===
# Allowlist strategy: ignore everything by default, then un-ignore the
# authored config we want shared. New runtime files Claude drops in here
# are ignored automatically — no need to chase them with new rules.
claude/.claude/*

# Authored config shared across machines:
!claude/.claude/agents/
!claude/.claude/skills/
!claude/.claude/commands/
!claude/.claude/hooks/
!claude/.claude/rules/
!claude/.claude/scripts/
!claude/.claude/CLAUDE.md
!claude/.claude/RTK.md
!claude/.claude/MCP_LOOP_README.md
!claude/.claude/settings.json
!claude/.claude/statusline-command.sh
!claude/.claude/policy-limits.json
!claude/.claude/.security-level

nvim/.config/nvim/lazy-lock.json

# Claude Code harness-managed runtime state (auto-refreshed by the CLI)
claude/.claude/policy-limits.json
