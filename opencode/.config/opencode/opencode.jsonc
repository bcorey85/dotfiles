{
  "$schema": "https://opencode.ai/config.json",
  "formatter": true,
  "lsp": true,
  "small_model": "opencode-go/deepseek-v4-flash",
  "permission": {
    "bash": {
      "sudo *": "deny",
      "rm -rf /": "deny",
      "rm -rf *": "deny",
      "chmod 777 *": "deny",
      "git push --force*": "deny",
      "git push -f *": "deny",
      "git reset --hard *": "deny",
      "git clean -f *": "deny",
      "git clean --force *": "deny",
      "git commit * --no-verify*": "deny",
      "git push * --no-verify*": "deny",
      "git merge * --no-verify*": "deny",
      "ssh *": "deny",
      "scp *": "deny",
      "rsync *": "deny",
      "eval *": "deny",
      "docker run * --privileged*": "deny",
      "terraform destroy*": "deny",
      "pulumi destroy*": "deny",
      "npm publish*": "deny",
      "pnpm publish*": "deny",
      "yarn publish*": "deny",
      "dd * of=*": "deny",
      "mkfs*": "deny",
      "kubectl delete*": "deny",
      "kubectl drain*": "deny",
      "helm uninstall*": "deny",
      "helm delete*": "deny"
    },
    "edit": {
      "~/.ssh/*": "deny",
      "~/.aws/*": "deny",
      "~/.kube/*": "deny",
      "~/.gnupg/*": "deny",
      "~/.docker/*": "deny",
      "~/.config/gcloud/*": "deny",
      "~/.gcloud/*": "deny",
      "~/.azure/*": "deny",
      "~/.zshrc": "deny",
      "~/.bashrc": "deny",
      "~/.bash_profile": "deny",
      "~/.profile": "deny",
      "~/.zprofile": "deny",
      "~/.zshenv": "deny",
      "~/.gitconfig": "deny",
      "~/.git-credentials": "deny",
      "~/.npmrc": "deny",
      "~/.pypirc": "deny",
      "~/.gem/credentials": "deny",
      "/etc/*": "deny",
      "/usr/*": "deny",
      "/bin/*": "deny",
      "/sbin/*": "deny",
      "~/.config/autostart/*": "deny",
      "~/.local/share/systemd/user/*": "deny",
      "~/.claude/settings.json": "deny",
      "~/.claude/settings.local.json": "deny",
      "~/.claude/scripts/*": "deny",
      "~/.claude/hooks/*": "deny",
      "~/.config/opencode/opencode.json": "deny",
      "~/.config/opencode/opencode.jsonc": "deny",
      "~/.env": "deny",
      "~/.envrc": "deny",
      "~/.env.*": "deny",
      "~/.env.example": "allow",
      "~/.env.sample": "allow",
      "~/.env.template": "allow",
      "*/.git/hooks/*": "deny",
      "*/.github/workflows/*": "deny",
      "*/.gitlab-ci.yml": "deny",
      "*/Jenkinsfile": "deny",
      "*/azure-pipelines.yml": "deny",
      "*/.travis.yml": "deny",
      "*/bitbucket-pipelines.yml": "deny",
      "*/.mcp.json": "deny"
    },
    "read": {
      "*": "allow",
      "~/.aws/credentials": "deny",
      "~/.aws/config": "deny",
      "~/.kube/config": "deny",
      "~/.ssh/id_*": "deny",
      "~/.ssh/authorized_keys": "deny",
      "~/.ssh/config": "deny",
      "~/.ssh/known_hosts": "deny",
      "~/*.pem": "deny",
      "~/*.key": "deny",
      "~/*.p12": "deny",
      "~/*.pfx": "deny",
      "~/.gnupg/*": "deny",
      "~/.env": "deny",
      "~/.envrc": "deny",
      "~/.env.*": "deny",
      "~/.env.example": "allow",
      "~/.env.sample": "allow",
      "~/.env.template": "allow",
      "~/.npmrc": "deny",
      "~/.pypirc": "deny",
      "~/.gem/credentials": "deny",
      "~/.git-credentials": "deny",
      "~/.netrc": "deny",
      "~/.config/gh/hosts.yml": "deny",
      "~/.vault-token": "deny",
      "~/.docker/config.json": "deny",
      "~/.config/gcloud/*": "deny",
      "~/.gcloud/*": "deny",
      "~/.azure/*": "deny",
      "~/.bash_history": "deny",
      "~/.zsh_history": "deny",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "*.env.sample": "allow",
      "*.env.template": "allow",
      "*.tfstate": "deny",
      "*credentials.json": "deny",
      "*service_account.json": "deny",
      "*application_default_credentials.json": "deny"
    }
  }
}
