#!/bin/bash
# Reading mode (bound to prefix-m in tmux): zoom the nvim pane and toggle
# reading mode in it (zen + readonly buffer + q to exit, util/reading.lua).
#
#   current pane is nvim          -> zoom it and toggle
#   another pane in window is nvim -> jump to it first, then zoom and toggle
#   no nvim pane                   -> message
#
# `@pane-is-vim` is set by smart-splits.nvim on startup. Both resize-pane -Z
# and toggle() are idempotent toggles, so running twice restores the original
# state.

if [ "$(tmux display-message -p '#{@pane-is-vim}')" = "1" ]; then
    vim_pane=$(tmux display-message -p '#{pane_id}')
else
    vim_pane=$(tmux list-panes -F '#{pane_id} #{@pane-is-vim}' | awk '$2==1{print $1; exit}')
fi

if [ -z "$vim_pane" ]; then
    tmux display-message 'no nvim pane in window'
    exit 0
fi

tmux select-pane -t "$vim_pane"
tmux resize-pane -t "$vim_pane" -Z
tmux send-keys -t "$vim_pane" Escape ":lua require('util.reading').toggle()" Enter
