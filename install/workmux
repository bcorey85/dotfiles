#!/bin/bash
set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

print_success() { echo -e "${GREEN}✓${NC} $1"; }
print_error() { echo -e "${RED}✗${NC} $1"; }
print_info() { echo -e "${YELLOW}→${NC} $1"; }

# workmux — git worktrees + tmux windows for parallel agent sessions
# (https://github.com/raine/workmux). macOS installs from the author's brew
# tap; Linux has no apt/pacman package, so install the prebuilt release
# binary (checksum-verified) into ~/.local/bin. Re-run with --update to
# upgrade an existing Linux binary install (brew handles its own upgrades).

if command -v workmux &>/dev/null && [ "$1" != "--update" ]; then
  print_success "workmux already installed ($(workmux --version 2>/dev/null || true)) — use --update to upgrade"
  exit 0
fi

if [ "$(uname -s)" = "Darwin" ]; then
  print_info "Installing workmux via Homebrew..."
  brew install raine/workmux/workmux
  print_success "workmux installed"
  exit 0
fi

case "$(uname -m)" in
  x86_64) ASSET_ARCH=amd64 ;;
  aarch64 | arm64) ASSET_ARCH=arm64 ;;
  *)
    print_error "Unsupported architecture: $(uname -m)"
    exit 1
    ;;
esac

ASSET="workmux-linux-${ASSET_ARCH}.tar.gz"
SHA_FILE="workmux-linux-${ASSET_ARCH}.sha256"
BASE_URL="https://github.com/raine/workmux/releases/latest/download"

TMP_DIR=$(mktemp -d)
trap 'rm -rf "$TMP_DIR"' EXIT

print_info "Downloading $ASSET..."
curl -fsSL -o "$TMP_DIR/$ASSET" "$BASE_URL/$ASSET"
curl -fsSL -o "$TMP_DIR/$SHA_FILE" "$BASE_URL/$SHA_FILE"
(cd "$TMP_DIR" && sha256sum --check --quiet "$SHA_FILE")

tar -xzf "$TMP_DIR/$ASSET" -C "$TMP_DIR"
mkdir -p "$HOME/.local/bin"
install -m 755 "$TMP_DIR/workmux" "$HOME/.local/bin/workmux"
print_success "workmux installed to ~/.local/bin ($("$HOME/.local/bin/workmux" --version 2>/dev/null || true))"

# Zsh completions — regenerate on every (re)install so they track the binary.
# ~/.zsh/completions is already on fpath in .zshrc; macOS gets these from the
# brew formula (that path exits above).
mkdir -p "$HOME/.zsh/completions"
"$HOME/.local/bin/workmux" completions zsh > "$HOME/.zsh/completions/_workmux"
print_success "zsh completions regenerated"
