    "deny": [
      "Bash(sudo *)",
      "Bash(rm -rf /)",
      "Bash(chmod 777 *)",
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)"
    ],
    "defaultMode": "auto"
  },
  "model": "opus",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/bash-safety-gate.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/git-discipline-gate.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/review-commit-gate.sh"
          }
        ]
      },
      {
        "matcher": "Read|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/block-credential-read.sh"
          }
        ]
      },
      {
        "matcher": "(Write|Edit|MultiEdit|NotebookEdit)",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/write-edit-safety-gate.sh"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/agent-model-guard.sh"
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/notify 'Claude Code' 'Question for you'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/log-skill-use.sh"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/review-commit-gate.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/scripts/log-agent-usage.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/stub-guard.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/prettier-hook.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/eslint-hook.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/claudemd-linecount.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/log-skill-use.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/notify 'Claude Code' 'Ready for input'"
          }
        ]
      },
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/notify 'Claude Code' 'Permission needed'"
          }
        ]
      },
      {
        "matcher": "task_complete",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/notify 'Claude Code' 'Task complete'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/warn-skip-hooks.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/scripts/calibration-guard.sh"
          }
        ]
      }
    ]
  },
  "worktree": {
    "baseRef": "fresh"
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "workmux-status@workmux": true
  },
  "extraKnownMarketplaces": {
    "workmux": {
      "source": {
        "source": "github",
        "repo": "raine/workmux"
      }
    }
  },
  "effortLevel": "high",
  "awaySummaryEnabled": false,
  "tui": "fullscreen",
  "autoMemoryEnabled": false,
  "skipWorkflowUsageWarning": true,
  "theme": "dark-ansi",
  "editorMode": "normal",
  "inputNeededNotifEnabled": false,
  "skipAutoPermissionPrompt": true
}
