      "Bash(pip3 show *)",
      "Bash(uv --version)",
      "Bash(uv version)",
      "Bash(uv tree)",
      "Bash(uv pip list *)",
      "Bash(uv pip show *)",
      "Bash(ruby --version)",
      "Bash(go version)",
      "Bash(go env *)",
      "Bash(rustc --version)",
      "Bash(cargo --version)",
      "Bash(cargo version)",
      "Bash(java -version)",
      "Bash(java --version)",
      "Bash(tsc --version)",
      "Bash(make --version)",
      "Bash(aws --version)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(curl --version)",
      "Bash(curl -s https://registry.npmjs.org/*)",
      "Bash(curl -s https://api.github.com/*)",
      "Bash(curl -s http://localhost*)",
      "Bash(curl -s http://127.0.0.1*)",
      "Bash(dig *)",
      "Bash(nslookup *)",
