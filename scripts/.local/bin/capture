#!/usr/bin/env bash
# capture — org-capture-style quick note/todo into the Obsidian inbox.
#
# Pops a scratch nvim buffer (seeded as a markdown todo, cursor in insert mode),
# and on save appends each non-empty line under today's date heading in the
# vault inbox. Open, jot, :wq — back to whatever you were doing. For a plain
# note instead of a todo, just clear the seeded "- [ ] " prefix.
#
# Designed to run inside a tmux display-popup (bound to prefix C-n) so it works
# over any pane, but it's a plain script — run `capture` anywhere.
set -euo pipefail

INBOX="${CAPTURE_INBOX:-$HOME/vault/00. Inbox/inbox.md}"
EDITOR_CMD="${EDITOR:-nvim}"

# Portable temp file with a .md extension (BSD mktemp has no --suffix).
tmp="$(mktemp "${TMPDIR:-/tmp}/capture.XXXXXX")"
mv "$tmp" "$tmp.md"
tmp="$tmp.md"
trap 'rm -f "$tmp"' EXIT

# Seed as a todo so the common case is zero-formatting; cursor lands after the
# checkbox in insert mode.
printf -- '- [ ] ' > "$tmp"
"$EDITOR_CMD" -c 'startinsert!' "$tmp"

# Strip trailing whitespace, drop blank lines and an untouched empty checkbox.
content="$(sed -e 's/[[:space:]]*$//' "$tmp" | sed '/^$/d' | sed '/^- \[ \]$/d')"
[ -z "$content" ] && exit 0

mkdir -p "$(dirname "$INBOX")"

# One date heading per day (org datetree-lite), so same-day captures group up.
today="$(date +%F)"
if [ ! -f "$INBOX" ] || ! grep -qxF "## $today" "$INBOX"; then
  { [ -s "$INBOX" ] && printf '\n'; printf '## %s\n\n' "$today"; } >> "$INBOX"
fi

printf '%s\n' "$content" >> "$INBOX"
