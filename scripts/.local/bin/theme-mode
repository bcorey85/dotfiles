#!/bin/bash
# theme-mode — single source of truth for light/dark across tmux + neovim.
#
# Writes the mode to a shared state file; tmux and nvim both read it:
#   - tmux: this script sources the matching ~/.config/tmux/{mode}.conf
#           so every client updates immediately.
#   - nvim: each instance polls the state file (see lua/config/theme-sync.lua)
#           and flips the active colorscheme dark <-> light within ~1s.
#
# Usage: theme-mode [dark|light|toggle]   (default: toggle)
set -euo pipefail

STATE_FILE="$HOME/.cache/theme-mode"
TMUX_THEME_DIR="$HOME/.config/tmux"

current() { cat "$STATE_FILE" 2>/dev/null | tr -d '[:space:]'; }

arg="${1:-toggle}"
case "$arg" in
  dark | light) mode="$arg" ;;
  toggle) [ "$(current)" = "light" ] && mode="dark" || mode="light" ;;
  *)
    echo "usage: theme-mode [dark|light|toggle]" >&2
    exit 2
    ;;
esac

# Write state (nvim picks this up via its poller).
mkdir -p "$(dirname "$STATE_FILE")"
printf '%s\n' "$mode" >"$STATE_FILE"

# Apply to tmux now, if a server is running. source-file is server-global, so
# every attached client updates at once.
if command -v tmux >/dev/null 2>&1 && tmux has-session >/dev/null 2>&1; then
  tmux source-file -q "$TMUX_THEME_DIR/$mode.conf" 2>/dev/null || true
  # Set cursor colour via tmux's built-in option (no escape sequences needed).
  cursor="#ffffff"
  [ "$mode" = "light" ] && cursor="#000000"
  tmux set-option -g cursor-colour "$cursor" 2>/dev/null || true
  # Re-arm tmux-continuum: its autosave trigger lives inside status-right,
  # which the theme file we just sourced overwrote. Re-running continuum.tmux
  # doesn't work here (its "another server running" heuristic misfires when
  # invoked mid-session), so prepend the interpolation directly — same logic
  # as continuum's add_resurrect_save_interpolation. No-op when not installed.
  cont_save="$HOME/.tmux/plugins/tmux-continuum/scripts/continuum_save.sh"
  if [ -f "$cont_save" ]; then
    sr="$(tmux show-option -gqv status-right 2>/dev/null || true)"
    case "$sr" in
      *continuum_save.sh*) : ;; # already armed
      *) tmux set-option -g status-right "#($cont_save)$sr" 2>/dev/null || true ;;
    esac
  fi
  tmux display-message "theme: $mode"
fi

echo "$mode"
