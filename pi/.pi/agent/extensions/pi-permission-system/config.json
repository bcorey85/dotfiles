{
  "$schema": "https://raw.githubusercontent.com/gotgenes/pi-permission-system/main/schemas/permissions.schema.json",

  "debugLog": false,
  "permissionReviewLog": true,
  "yoloMode": false,

  "permission": {
    "*": "allow",
    "bash": {
      "*": "allow",
      "git add *": "ask",
      "git commit *": "ask",
      "git push *": "ask",
      "git reset *": "ask",
      "git checkout -- *": "ask",
      "git clean *": "ask",
      "git merge *": "ask",
      "git rebase *": "ask",
      "git rm *": "ask",
      "git branch -D *": "ask",
      "git stash drop *": "ask",
      "git tag *": "ask",
      "rm -rf *": "deny",
      "sudo *": "ask",
      "chmod 777 *": "deny",
      "mv *": "ask"
    },
    "read": "allow",
    "write": "allow",
    "edit": "allow",
    "path": {
      "*": "allow",
      "*.env": "deny",
      ".env": "deny",
      "**/.env": "deny",
      "**/*.env": "deny",
      "*.env.*": "deny",
      "**/*.env.*": "deny",
      "*.pem": "deny",
      "**/*.pem": "deny",
      "*.key": "deny",
      "**/*.key": "deny",
      "*credentials.json": "deny",
      "**/*credentials.json": "deny",
      "*service_account.json": "deny",
      "**/*service_account.json": "deny",
      "**/.ssh/*": "deny",
      "**/.aws/*": "deny",
      "**/.kube/*": "deny",
      "**/.git-credentials": "deny",
      "~/.zshrc.local": "deny",
      "~/.gitconfig.local": "deny",
      "*.env.example": "allow",
      "**/*.env.example": "allow"
    },
    "external_directory": {
      "*": "ask",
      "/tmp/*": "allow",
      "$HOME/.cargo/registry/*": "allow",
      "$HOME/.cache/*": "allow"
    }
  }
}
