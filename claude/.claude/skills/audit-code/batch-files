#!/usr/bin/env bash
# batch-files — deterministic round-robin batching for /audit-code
#
# stdin:  newline-separated file paths
# stdout: batches as "# batch N of M (K files)" headers followed by the paths
#
# Sorts the input, computes batch count = min(max-batches, ceil(n / per-batch)),
# then assigns file i -> batch (i % count). Identical scope always produces
# identical batches — no LLM judgment involved.
#
# usage: batch-files [--per-batch N] [--max-batches N] < filelist
set -euo pipefail

per_batch=25
max_batches=4
while [ $# -gt 0 ]; do
  case "$1" in
    --per-batch)   per_batch="$2"; shift 2 ;;
    --max-batches) max_batches="$2"; shift 2 ;;
    *) echo "usage: batch-files [--per-batch N] [--max-batches N] < filelist" >&2; exit 2 ;;
  esac
done

sort -u | awk -v per="$per_batch" -v maxb="$max_batches" '
  NF { files[n++] = $0 }
  END {
    if (n == 0) { print "no files on stdin" > "/dev/stderr"; exit 1 }
    b = int((n + per - 1) / per)
    if (b > maxb) b = maxb
    if (b < 1) b = 1
    for (i = 0; i < b; i++) {
      c = 0
      for (j = i; j < n; j += b) c++
      printf "# batch %d of %d (%d files)\n", i + 1, b, c
      for (j = i; j < n; j += b) print files[j]
      print ""
    }
  }'
