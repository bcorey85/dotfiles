#!/bin/bash
# Launch a coding layout for a project.
# Usage: dev [directory]
#   If a directory is provided, all panes/windows open there; otherwise cwd.
#
# Layout:
#   Window 1 "code"     nvim full-width — claude now lives in a popup session
#                       (prefix y, tmux-claude-session-manager); uncomment the
#                       split below to restore the old nvim (60%) | claude (40%)
#   Window 2 "console"  three equal shells for git / tests / logs

if [ -z "$TMUX" ]; then
    echo "Not in a tmux session"
    exit 1
fi

dir="${1:-.}"
dir="$(cd "$dir" && pwd)" || { echo "dev: no such directory: ${1:-.}" >&2; exit 1; }

# Window 1 "code": nvim full-width. Claude split disabled while trialing
# tmux-claude-session-manager popups (prefix y) — uncomment to restore.
# -p 40 sizes the NEW (right) pane to 40%, leaving nvim at 60%.
# Using -p instead of -l 40% for compatibility with older tmux (Ubuntu/WSL).
tmux rename-window "code"
tmux send-keys "nvim ." C-m
# tmux split-window -h -p 40 -c "$dir"
# tmux send-keys "claude" C-m
# tmux select-pane -L          # land on the editor

# Window 2 "console": three equal shells side by side
tmux new-window -n "console" -c "$dir"
tmux split-window -h -c "$dir"
tmux split-window -h -c "$dir"
tmux select-layout even-horizontal
tmux select-pane -t 1        # focus the leftmost shell

# Back to the code window, editor pane
tmux select-window -t 1
