{
  "env": {
    "ENABLE_LSP_TOOL": "1",
    "ENABLE_TOOL_SEARCH": "1",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1",
    "CLAUDE_CODE_SUBAGENT_MODEL": "sonnet"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs",
      "WebSearch",
      "Skill",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(pwd)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(command -v *)",
      "Bash(type *)",
      "Bash(uname *)",
      "Bash(date *)",
      "Bash(dirname *)",
      "Bash(basename *)",
      "Bash(realpath *)",
      "Bash(readlink *)",
      "Bash(whoami)",
      "Bash(id)",
      "Bash(hostname)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(diff *)",
      "Bash(jq *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(mkdir -p *)",
      "Bash(mkdir *)",
      "Bash(man *)",
      "Bash(node --version)",
      "Bash(node -v)",
      "Bash(node --help *)",
      "Bash(npm --version)",
      "Bash(npm list *)",
      "Bash(npm ls *)",
      "Bash(pnpm --version)",
      "Bash(pnpm build*)",
      "Bash(pnpm lint*)",
      "Bash(pnpm test*)",
      "Bash(pnpm ci:*)",
      "Bash(pnpm exec vitest *)",
      "Bash(pnpm exec playwright *)",
      "Bash(pnpm list *)",
      "Bash(pnpm ls *)",
      "Bash(pnpm why *)",
      "Bash(pnpm size*)",
      "Bash(pnpm knip*)",
      "Bash(pnpm jscpd*)",
      "Bash(pnpm changeset*)",
      "Bash(pnpm type-coverage*)",
      "Bash(pnpm vue:api:*)",
      "Bash(pnpm format*)",
      "Bash(pnpm mutation*)",
      "Bash(pnpm api:*)",
      "Bash(npx vitest *)",
      "Bash(python --version)",
      "Bash(python3 --version)",
      "Bash(pip list *)",
      "Bash(pip3 list *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(stow *)",
      "Bash(tree *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(du *)",
      "Bash(df *)",
      "Bash(nvm use*)",
      "Bash(source ~/.nvm/nvm.sh *)"
    ],
    "deny": [],
    "defaultMode": "auto"
  },
  "model": "sonnet",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/bash-safety-gate.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/write-edit-safety-gate.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/block-credential-read.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/legalfit/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/legalfit/.claude/hooks/sonar-secrets/build-scripts/pretool-secrets.sh",
            "timeout": 60
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/sonar-secrets/build-scripts/pretool-secrets.sh",
            "timeout": 60
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/prettier-hook.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/eslint-hook.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/claudemd-linecount.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/notify 'Claude Code' 'Ready for input'"
          }
        ]
      },
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/notify 'Claude Code' 'Permission needed'"
          }
        ]
      },
      {
        "matcher": "task_complete",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/notify 'Claude Code' 'Task complete'"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/legalfit/.claude/hooks/sonar-secrets/build-scripts/prompt-secrets.sh",
            "timeout": 60
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/sonar-secrets/build-scripts/prompt-secrets.sh",
            "timeout": 60
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "sonarqube-agent-plugins@claude-plugins-official": true
  },
  "autoMemoryEnabled": false,
  "skipAutoPermissionPrompt": true
}
