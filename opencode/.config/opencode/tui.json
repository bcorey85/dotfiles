{
  "$schema": "https://opencode.ai/tui.json",
  "diff_style": "stacked",
  "attention": {
    "enabled": true,
    "notifications": true,
    "sound": false,
    "volume": 0.4
  },
  "keybinds": {
    "which_key_toggle": "<leader>w",
    "app_exit": "ctrl+c,<leader>q",
    "session_delete": "none",
    "messages_next": "<leader>j",
    "messages_previous": "<leader>k"
  }
}
