[global]
    monitor = 0
    follow = mouse
    width = 350
    height = (0, 150)
    origin = top-right
    offset = (20, 20)
    notification_limit = 5
    indicate_hidden = yes

    # Appearance
    transparency = 0
    separator_height = 2
    separator_color = frame
    padding = 16
    horizontal_padding = 16
    text_icon_padding = 16
    frame_width = 2
    corner_radius = 8
    gap_size = 8

    # Font
    font = CommitMono Nerd Font Mono 11

    # Markup
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    word_wrap = yes
    ellipsize = end

    # Icons
    icon_position = left
    min_icon_size = 32
    max_icon_size = 48

    # History
    sticky_history = yes
    history_length = 20

    # Misc
    browser = /usr/bin/xdg-open
    mouse_left_click = do_action, close_current
    mouse_middle_click = close_all
    mouse_right_click = close_current

# Suppress YouTube notifications (Chrome web-push).
# Chrome sets appname="Google Chrome" for all sites, so we discriminate on the
# youtube.com URL that Chrome embeds in the body. Matching is case-sensitive,
# so this must be lowercase to match the href.
[suppress_youtube]
    appname = "Google Chrome"
    body = "*youtube.com*"
    skip_display = yes
    history_ignore = yes

[urgency_low]
    background = "#1c2128"
    foreground = "#768390"
    frame_color = "#444c56"
    highlight = "#539bf5"
    timeout = 5

[urgency_normal]
    background = "#1c2128"
    foreground = "#adbac7"
    frame_color = "#539bf5"
    highlight = "#539bf5"
    timeout = 10

[urgency_critical]
    background = "#1c2128"
    foreground = "#adbac7"
    frame_color = "#ff938a"
    highlight = "#ff938a"
    timeout = 0
