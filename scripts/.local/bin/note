#!/bin/bash
# Frictionless capture: append a timestamped one-liner to today's org journal.
# No structure on purpose — the nightly daily-recap compile classifies these
# into decisions/roadblocks/follow-ups. Capture is the human's job, structure
# is the machine's. Complements `todo` (task lane → agenda): notes are things
# that HAPPENED, todos are things to DO.
#
# Appends a flat same-day heading rather than threading nvim-orgmode's datetree:
# daily-recap matches any heading whose title starts with today's date and
# tolerates these alongside the datetree, so a plain append stays parseable
# without reimplementing datetree insertion in bash.
set -e

VAULT="${VAULT_DIR:-$HOME/vault}"
ORG="$VAULT/org"
FILE="$ORG/journal.org"

if [ $# -eq 0 ]; then
  echo "usage: note <text>    e.g. note cdc - platform blocked on auth schema" >&2
  exit 1
fi

mkdir -p "$ORG"
printf -- '* %s\n  %s\n' "$(date +'%Y-%m-%d %a %H:%M')" "$*" >>"$FILE"
