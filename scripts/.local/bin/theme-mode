#!/bin/bash
# theme-mode — single source of truth for the theme FAMILY and light/dark MODE
# across tmux + neovim + ghostty + claude code.
#
# State files (read by every consumer):
#   ~/.cache/theme-mode    dark|light
#   ~/.cache/theme-family  family name (see families() below)
#
# Consumers:
#   - tmux:    this script sources ~/.config/tmux/<family>-<mode>.conf
#   - nvim:    lua/config/theme-sync.lua polls both files (~1s) and applies
#              the family's colorscheme + overrides
#   - emacs:   watches the mode file only (family stays github-remapped modus)
#   - ghostty: this script writes ~/.config/ghostty/theme-switch.conf
#              (machine-local include, same pattern as font-mode.conf), then
#              SIGUSR2s the running ghostty to reload it (1.2+; ctrl+shift+,
#              still works by hand). Only USR2 — any other signal crashes it.
#   - workmux: this script sets the tmux-global $COLORFGBG (mode only, no
#              family); the dashboard popup inherits it and picks light/dark.
#   - claude:  this script writes .theme (mode only) into ~/.claude/settings.json
#              via jq; claude code watches the file and hot-reloads live. Bypasses
#              its OSC 11 auto-detection, which tmux mangles and only samples at
#              launch (a runtime flip never reaches a running session).
#   - starship: this script regenerates ~/.cache/starship.toml (mode only) from
#              the stowed template with the active `palette =` line swapped;
#              .zshrc points STARSHIP_CONFIG at the cache. Starship has no
#              include but re-reads its config every prompt, so the next prompt
#              flips. Edit the template => re-run theme-mode to refresh the cache.
#
# Usage:
#   theme-mode [dark|light|toggle]    flip mode, keep family (default: toggle)
#   theme-mode use <family> [mode]    switch family, keep mode unless given
#   theme-mode list                   known families
#   theme-mode status                 current family + mode
#
# Adding a family = four touchpoints, kept in sync by hand:
#   1. families() + ghostty_theme() below
#   2. FAMILIES table in nvim lua/config/theme-sync.lua
#   3. ~/.config/tmux/<family>-{dark,light}.conf
#   4. a ghostty theme (builtin name, or custom file in ghostty/themes/)
set -euo pipefail

MODE_FILE="$HOME/.cache/theme-mode"
FAMILY_FILE="$HOME/.cache/theme-family"
TMUX_THEME_DIR="$HOME/.config/tmux"
GHOSTTY_SWITCH="$HOME/.config/ghostty/theme-switch.conf"
DEFAULT_FAMILY="nightfox"

families() { printf '%s\n' nightfox duskfox nordfox terafox carbonfox; }

ghostty_theme() { # <family> <mode> -> ghostty theme name
  case "$1:$2" in
    # custom: Nightfox blazes the usual way (7/15 above body fg); Dayfox hits
    # the inverse on a light bg — its 15 (#f4ece6) is a hair off the background.
    nightfox:*) echo "nightfox-$2" ;; # custom: ghostty/themes/nightfox-{dark,light} (dayfox is the light)
    duskfox:*) echo "duskfox-$2" ;; # custom: ghostty/themes/duskfox-{dark,light} (rose-pine-derived; dawnfox is the light)
    nordfox:*) echo "nordfox-$2" ;; # custom: ghostty/themes/nordfox-{dark,light} (Nord; dayfox is the light)
    terafox:*) echo "terafox-$2" ;; # custom: ghostty/themes/terafox-{dark,light} (dawnfox is the light)
    carbonfox:*) echo "carbonfox-$2" ;; # custom: ghostty/themes/carbonfox-{dark,light} (IBM Carbon; dayfox is the light)
  esac
}

current_mode() { cat "$MODE_FILE" 2>/dev/null | tr -d '[:space:]'; }
current_family() {
  local f
  f="$(cat "$FAMILY_FILE" 2>/dev/null | tr -d '[:space:]')"
  families | grep -qx "$f" && echo "$f" || echo "$DEFAULT_FAMILY"
}

apply() { # <family> <mode> — write state and repaint tmux + ghostty
  local family="$1" mode="$2"
  mkdir -p "$(dirname "$MODE_FILE")"
  printf '%s\n' "$mode" >"$MODE_FILE"     # nvim + emacs pick these up
  printf '%s\n' "$family" >"$FAMILY_FILE" # via their own watchers

  # ghostty: machine-local include; wins over the fallback `theme =` line
  # because config-file includes are processed after the main config.
  #
  # Custom themes are pulled in by ABSOLUTE PATH, not by name. `theme = <name>`
  # resolves against a themes/ dir inside whatever ghostty considers its config
  # directory — on macOS that's ~/Library/Application Support/com.mitchellh.ghostty/,
  # NOT the stowed ~/.config/ghostty/, so every custom theme 404s there while
  # builtins keep working. A theme file is just a config fragment (palette /
  # background / foreground), so config-file loads it identically on any
  # platform. Builtins have no file on disk and still go through `theme =`.
  mkdir -p "$(dirname "$GHOSTTY_SWITCH")"
  local theme custom
  theme="$(ghostty_theme "$family" "$mode")"
  custom="$(dirname "$GHOSTTY_SWITCH")/themes/$theme"
  {
    echo "# Written by theme-mode — do not edit. Reload ghostty: ctrl+shift+,"
    if [ -f "$custom" ]; then
      echo "config-file = $custom"
    else
      echo "theme = $theme"
    fi
  } >"$GHOSTTY_SWITCH"

  # Ghostty reloads its config on SIGUSR2 (1.2+). Without this the include above
  # sits on disk until you hit ctrl+shift+, by hand. USR2 ONLY — ghostty crashes
  # on any other signal. macOS runs the same binary name from the app bundle.
  if command -v pkill >/dev/null 2>&1; then
    pkill -USR2 -x ghostty 2>/dev/null || true
  fi

  # Claude Code: it watches ~/.claude/settings.json and hot-reloads `theme`
  # live (only `model`/`outputStyle` are restart-only). Its `auto` theme relies
  # on an OSC 11 background query that tmux mangles and only samples at launch,
  # so a runtime flip never reaches a running session — push the mode in
  # explicitly instead. `light`/`dark` are valid theme values, so $mode drops
  # straight in.
  local claude_settings="$HOME/.claude/settings.json"
  if command -v jq >/dev/null 2>&1 && [ -f "$claude_settings" ]; then
    local claude_tmp
    claude_tmp="$(mktemp)"
    if jq --arg t "$mode" '.theme = $t' "$claude_settings" >"$claude_tmp" 2>/dev/null; then
      mv "$claude_tmp" "$claude_settings"
    else
      rm -f "$claude_tmp"
    fi
  fi

  # Starship: no include mechanism, but it re-reads its whole config every
  # prompt. Regenerate a machine-local cache from the stowed template with the
  # active `palette =` line swapped to $mode; STARSHIP_CONFIG (set in .zshrc)
  # points here, so the next prompt flips. Only the top-level `palette = ` line
  # matches the anchored sed — the [palettes.*] headers are untouched.
  local starship_src="$HOME/.config/starship.toml"
  local starship_cache="$HOME/.cache/starship.toml"
  if [ -f "$starship_src" ]; then
    sed "s/^palette = .*/palette = \"$mode\"/" "$starship_src" >"$starship_cache"
  fi

  # tmux: source-file is server-global, every attached client updates at once.
  if command -v tmux >/dev/null 2>&1 && tmux has-session >/dev/null 2>&1; then
    tmux source-file -q "$TMUX_THEME_DIR/$family-$mode.conf" 2>/dev/null || true
    # Cursor colour via tmux's built-in option (no escape sequences needed).
    local cursor="#ffffff"
    [ "$mode" = "light" ] && cursor="#000000"
    tmux set-option -g cursor-colour "$cursor" 2>/dev/null || true
    # workmux's dashboard (prefix W / C-.) auto-detects light/dark via an OSC 11
    # background query. tmux popups don't answer that reliably, so it falls back
    # to $COLORFGBG — unset by default, which lands it in dark mode on a light
    # terminal. Publish COLORFGBG into the tmux global env: popups inherit it and
    # the dashboard spawns fresh each open, so it tracks the mode. Convention is
    # fg;bg by ANSI slot — bg 15 (light) => light theme, bg 0 (dark) => dark.
    local colorfgbg="15;0"
    [ "$mode" = "light" ] && colorfgbg="0;15"
    tmux set-environment -g COLORFGBG "$colorfgbg" 2>/dev/null || true
    # Re-arm tmux-continuum: its autosave trigger lives inside status-right,
    # which the theme file we just sourced overwrote. Re-running continuum.tmux
    # doesn't work here (its "another server running" heuristic misfires when
    # invoked mid-session), so prepend the interpolation directly — same logic
    # as continuum's add_resurrect_save_interpolation. No-op when not installed.
    local cont_save="$HOME/.tmux/plugins/tmux-continuum/scripts/continuum_save.sh"
    if [ -f "$cont_save" ]; then
      local sr
      sr="$(tmux show-option -gqv status-right 2>/dev/null || true)"
      case "$sr" in
        *continuum_save.sh*) : ;; # already armed
        *) tmux set-option -g status-right "#($cont_save)$sr" 2>/dev/null || true ;;
      esac
    fi
    # Re-arm the workmux attention segment for the same reason as continuum:
    # the theme file just rewrote status-right. No-op without workmux.
    "$HOME/.local/bin/tmux-arm-workmux-segment" 2>/dev/null || true
    tmux display-message "theme: $family $mode"
  fi

  echo "$family $mode"
}

arg="${1:-toggle}"
case "$arg" in
  dark | light) apply "$(current_family)" "$arg" ;;
  toggle)
    [ "$(current_mode)" = "light" ] && mode="dark" || mode="light"
    apply "$(current_family)" "$mode"
    ;;
  use)
    family="${2:-}"
    if ! families | grep -qx "$family"; then
      echo "unknown family: '$family' (see: theme-mode list)" >&2
      exit 2
    fi
    mode="${3:-$(current_mode)}"
    case "$mode" in dark | light) : ;; *) mode="dark" ;; esac
    apply "$family" "$mode"
    ;;
  list) families ;;
  status) echo "$(current_family) $(current_mode)" ;;
  *)
    echo "usage: theme-mode [dark|light|toggle] | use <family> [mode] | list | status" >&2
    exit 2
    ;;
esac
