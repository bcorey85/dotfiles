#!/bin/bash
set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

print_success() { echo -e "${GREEN}✓${NC} $1"; }
print_error() { echo -e "${RED}✗${NC} $1"; }
print_info() { echo -e "${YELLOW}→${NC} $1"; }

# daily-recap — schedules a headless `claude -p "/daily-recap"` run at 18:00
# on weekdays. The skill (claude/.claude/skills/daily-recap) compiles the
# day's org captures (~/vault/org: journal + todo activity) + GitHub activity
# into a structured daily note in the vault.
#   macOS: LaunchAgent (~/Library/LaunchAgents/com.dotfiles.daily-recap.plist);
#          a run missed while asleep fires on next wake.
#   Linux: systemd user timer with Persistent=true (missed runs fire on boot).
# Skips (not fails) if claude is absent — re-run after installing Claude Code.

if ! command -v claude &>/dev/null; then
  print_info "claude not installed — skipping (install Claude Code, then re-run install/daily-recap)"
  exit 0
fi

# Absolute claude path, resolved at install time: systemd's `zsh -l` only
# sources .zprofile, not .zshrc where ~/.local/bin joins PATH — a bare
# `claude` exits 127 there. Re-run this installer if claude moves. gh/date/
# mkdir are system packages, already on the service PATH. Allowlist is the
# minimum the skill needs to run unattended (vault writes + gh reads).
RECAP_CMD="$(command -v claude)"' --permission-mode acceptEdits --allowedTools Read Write Edit Glob Grep "Bash(gh:*)" "Bash(date:*)" "Bash(mkdir:*)" -p "/daily-recap"'

# Empty-day guard: the scheduler runs a generated wrapper, not claude directly.
# The wrapper exits 0 without starting claude when there are no org captures
# modified today AND no GitHub events today — quiet days cost zero tokens.
WRAPPER="$HOME/.local/bin/daily-recap-run"
mkdir -p "$HOME/.local/bin"
cat >"$WRAPPER" <<'EOF'
#!/bin/bash
# generated by install/daily-recap — re-run that installer to regenerate
set -e
has_activity() {
  find "$HOME/vault/org" -type f -newermt "$(date +%F)" 2>/dev/null | grep -qm1 . && return 0
  command -v gh >/dev/null && gh auth status &>/dev/null || return 1
  login=$(gh api user --jq .login 2>/dev/null) || return 1
  count=$(gh api "users/$login/events?per_page=50" --jq --arg d "$(date -u +%F)" '[.[] | select(.created_at | startswith($d))] | length' 2>/dev/null) || return 1
  [ "${count:-0}" -gt 0 ]
}
if ! has_activity; then
  echo "$(date '+%F %T') no org captures or GitHub activity today — skipping recap"
  exit 0
fi
EOF
echo "exec $RECAP_CMD" >>"$WRAPPER"
chmod +x "$WRAPPER"

if [[ "$(uname)" == "Darwin" ]]; then
  PLIST="$HOME/Library/LaunchAgents/com.dotfiles.daily-recap.plist"
  mkdir -p "$HOME/Library/LaunchAgents" "$HOME/Library/Logs"

  cat >"$PLIST" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>com.dotfiles.daily-recap</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-l</string>
    <string>-c</string>
    <string>$WRAPPER || osascript -e 'display notification "see ~/Library/Logs/daily-recap.log" with title "daily-recap failed"'</string>
  </array>
  <key>StartCalendarInterval</key>
  <array>
    <dict><key>Weekday</key><integer>1</integer><key>Hour</key><integer>18</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Weekday</key><integer>2</integer><key>Hour</key><integer>18</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Weekday</key><integer>3</integer><key>Hour</key><integer>18</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Weekday</key><integer>4</integer><key>Hour</key><integer>18</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Weekday</key><integer>5</integer><key>Hour</key><integer>18</integer><key>Minute</key><integer>0</integer></dict>
  </array>
  <key>StandardOutPath</key><string>$HOME/Library/Logs/daily-recap.log</string>
  <key>StandardErrorPath</key><string>$HOME/Library/Logs/daily-recap.log</string>
</dict>
</plist>
EOF

  launchctl unload "$PLIST" 2>/dev/null || true
  launchctl load "$PLIST"
  print_success "LaunchAgent loaded — weekdays 18:00, logs at ~/Library/Logs/daily-recap.log"
  print_info "test now with: launchctl start com.dotfiles.daily-recap"
elif command -v systemctl &>/dev/null && systemctl --user show-environment &>/dev/null; then
  UNIT_DIR="$HOME/.config/systemd/user"
  mkdir -p "$UNIT_DIR"

  # Failure notifier shared by all recap services (install/weekly-recap writes
  # the same file): a headless run that dies silently erodes trust in the
  # pipeline, so surface it on the desktop. No-op if libnotify is absent.
  cat >"$UNIT_DIR/recap-notify@.service" <<'EOF'
[Unit]
Description=Desktop notification when %i fails

[Service]
Type=oneshot
ExecStart=/bin/sh -c 'command -v notify-send >/dev/null && exec notify-send -u critical "%i failed" "check: journalctl --user -u %i" || true'
EOF

  cat >"$UNIT_DIR/daily-recap.service" <<EOF
[Unit]
Description=Compile daily recap note from vault captures and GitHub activity
OnFailure=recap-notify@%p.service

[Service]
Type=oneshot
ExecStart=/bin/zsh -l -c '$WRAPPER'
EOF

  cat >"$UNIT_DIR/daily-recap.timer" <<EOF
[Unit]
Description=Run daily-recap at 18:00 on weekdays

[Timer]
OnCalendar=Mon..Fri 18:00
Persistent=true

[Install]
WantedBy=timers.target
EOF

  systemctl --user daemon-reload
  systemctl --user enable --now daily-recap.timer
  print_success "systemd user timer enabled — weekdays 18:00 (Persistent=true)"
  print_info "test now with: systemctl --user start daily-recap.service"
else
  print_info "no launchd or systemd user session (WSL?) — run 'claude -p \"/daily-recap\"' manually or from cron"
  exit 0
fi
