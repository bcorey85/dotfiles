#!/bin/bash
# vault-sync — one-shot stage/commit/pull/push for the notes vault, replacing
# the manual cd + add + commit + push dance. Safe to run with nothing to sync
# (still pulls/pushes so a behind/ahead vault converges). The vault is a
# personal notes repo: committing straight to its default branch is the point.
set -euo pipefail

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

VAULT="${VAULT_DIR:-$HOME/vault}"
cd "$VAULT"
git rev-parse --is-inside-work-tree >/dev/null

if [ -n "$(git status --porcelain)" ]; then
  git add -A
  git commit -m "vault sync $(date '+%F %H:%M')"
  echo -e "${GREEN}✓${NC} committed"
else
  echo -e "${YELLOW}→${NC} nothing to commit"
fi

git pull --rebase --autostash
git push
echo -e "${GREEN}✓${NC} vault synced"
