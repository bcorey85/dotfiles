#!/bin/bash
# Screenshot tool
# Usage: hypr-screenshot        - full screen
#        hypr-screenshot region  - select region (saves + copies to clipboard)

DIR="$HOME/Pictures/Screenshots"
FILE="$DIR/$(date +%Y%m%d_%H%M%S).png"

mkdir -p "$DIR"

if [ "$1" = "region" ]; then
    grim -g "$(slurp)" "$FILE"
else
    grim "$FILE"
fi

if [ -f "$FILE" ]; then
    wl-copy < "$FILE"
    notify-send "Screenshot saved" "$FILE"
fi
