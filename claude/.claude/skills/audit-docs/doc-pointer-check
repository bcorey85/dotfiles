#!/usr/bin/env bash
# doc-pointer-check — mechanical checks for /audit-docs (Checks 1 & 2)
#
# usage: doc-pointer-check <dir> [<dir>...]
#
# Check 1 (pointer):  backticked `path.ext[:NN]` and bare path/file.ext[:NN] refs
#                     that don't resolve, or cite a line more than 10 past EOF.
#                     Paths are resolved against the doc's git repo root, then
#                     the doc's own directory.
# Check 2 (temporal): time-relative phrases that age silently, and hardcoded
#                     YYYY-MM-DD dates older than 30 days.
#
# output: TSV  check<TAB>doc:line<TAB>detail   (one finding per line)
set -uo pipefail

[ $# -ge 1 ] || { echo "usage: doc-pointer-check <dir> [<dir>...]" >&2; exit 2; }

to_epoch() {
  date -u -d "$1" +%s 2>/dev/null || date -u -j -f "%Y-%m-%d" "$1" +%s 2>/dev/null || echo 0
}
now=$(date -u +%s)

resolve() { # resolve a doc-relative or repo-relative path; prints resolved path or nothing
  local doc_dir="$1" ref="$2" root
  [ -f "$doc_dir/$ref" ] && { printf '%s\n' "$doc_dir/$ref"; return; }
  root=$(git -C "$doc_dir" rev-parse --show-toplevel 2>/dev/null) || root=""
  [ -n "$root" ] && [ -f "$root/$ref" ] && { printf '%s\n' "$root/$ref"; return; }
  [ -f "$ref" ] && printf '%s\n' "$ref"
}

TEMPORAL='\b([Tt]oday|[Cc]urrently|[Rr]ight now|[Aa]t the moment|[Aa]s of (today|now)|[Tt]his (week|month|quarter|year)|([Ll]ast|[Nn]ext) (week|month|quarter)|[Rr]ecently|[Ll]ately|[Jj]ust (added|shipped|landed))\b'
EXTS='(ts|tsx|js|jsx|py|rb|go|rs|sql|yaml|yml|json|sh|lua|md|vue)'

for dir in "$@"; do
  [ -d "$dir" ] || { echo "skip: $dir is not a directory" >&2; continue; }
  find "$dir" -name '*.md' -not -path '*/node_modules/*' | sort | while IFS= read -r doc; do
    doc_dir=$(dirname "$doc")

    # ---- Check 1: code pointers ----
    grep -onE '`[^`]+\.[a-z]+(:[0-9]+)?`|(^|[^`/A-Za-z0-9_.-])[A-Za-z0-9_.-]+(/[A-Za-z0-9_.-]+)+\.'"$EXTS"'(:[0-9]+)?\b' "$doc" 2>/dev/null \
      | sed 's/`//g' | while IFS=: read -r lineno rest; do
        ref=$(printf '%s' "$rest" | grep -oE '[A-Za-z0-9_./-]+\.[a-z]+(:[0-9]+)?' | head -1)
        [ -n "$ref" ] || continue
        case "$ref" in
          http*|*example*|*placeholder*|path/to/*) continue ;;
        esac
        cited_line=""
        file_part="$ref"
        if printf '%s' "$ref" | grep -qE ':[0-9]+$'; then
          cited_line="${ref##*:}"
          file_part="${ref%:*}"
        fi
        target=$(resolve "$doc_dir" "$file_part")
        if [ -z "$target" ]; then
          printf 'pointer\t%s:%s\t%s — file not found\n' "$doc" "$lineno" "$ref"
        elif [ -n "$cited_line" ]; then
          total=$(wc -l < "$target" | tr -d ' ')
          if [ "$cited_line" -gt $((total + 10)) ]; then
            printf 'pointer\t%s:%s\t%s — line out of range (file has %s lines)\n' "$doc" "$lineno" "$ref" "$total"
          fi
        fi
      done

    # ---- Check 2a: temporal phrases ----
    grep -onE "$TEMPORAL" "$doc" 2>/dev/null | while IFS=: read -r lineno phrase; do
      printf 'temporal\t%s:%s\t"%s"\n' "$doc" "$lineno" "$phrase"
    done

    # ---- Check 2b: hardcoded dates older than 30 days ----
    grep -onE '\b[0-9]{4}-[0-9]{2}-[0-9]{2}\b' "$doc" 2>/dev/null | while IFS=: read -r lineno d; do
      ep=$(to_epoch "$d")
      [ "$ep" -eq 0 ] && continue
      age_days=$(( (now - ep) / 86400 ))
      if [ "$age_days" -gt 30 ]; then
        printf 'temporal\t%s:%s\tdate %s is %s days old\n' "$doc" "$lineno" "$d" "$age_days"
      fi
    done
  done
done
exit 0
