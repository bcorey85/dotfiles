# Font — JetBrains Mono, chosen after an audition for its tall x-height and
# sturdy weight (far less eye-strain than CommitMono for all-day reading).
font-family = JetBrainsMono Nerd Font Mono
font-style = Medium
font-size = 11
adjust-cell-height = 30%
confirm-close-surface = false

# Linux/FreeType only: disable light hinting (on by default in 1.3+) so glyph
# stems render heavier — closest match to kitty's bolder text rendering, since
# font-thicken is macOS-only. If still too light, use `font-style = Bold`.
freetype-load-flags = no-light
# Theme - modus-vivendi default (miikanissi/modus-themes.nvim)
background = #161616
foreground = #f2f4f8

selection-foreground = #ffffff
selection-background = #7030af

cursor-color = #f2f4f8
cursor-text = #161616

# Color palette — modus-vivendi deuteranopia terminal colors
palette = 0=#000000
palette = 1=#ff5f59
palette = 2=#44bc44
palette = 3=#d0bc00
palette = 4=#2fafff
palette = 5=#feacd0
palette = 6=#00d3d0
palette = 7=#ffffff
palette = 8=#303030
palette = 9=#ff5f5f
palette = 10=#44df44
palette = 11=#efef00
palette = 12=#338fff
palette = 13=#ff66ff
palette = 14=#00eff0
palette = 15=#989898

# Window
window-padding-x = 4
window-padding-y = 4

# Shell integration
shell-integration = detect

# macOS cmd key mappings. Option/Command are swapped in System Settings and
# aerospace owns real Option, so the physical "Alt" key emits Command (super) —
# these binds turn that back into the Alt sequences tmux/smart-splits expect.
keybind = super+j=text:\x1bj
keybind = super+k=text:\x1bk
keybind = super+l=text:\x1bl
keybind = super+semicolon=text:\x1b;

# Harpoon jumps: send tmux's M-1..4 as CSI-u (codepoint 49-52 + modifier 3=alt).
# Mirrors kitty's `map cmd+N send_text \x1b[<cp>;3u`; tmux has extended-keys on
# so it reads these as Alt+1..4. NOTE: the digit key is named `digit_N`, not
# `one`/`1` — and Ghostty 1.2.0+ binds cmd+1..9 to goto_tab by default, so this
# rebind is what reclaims them (a mismatched key name silently loses to that).
keybind = super+digit_1=csi:49;3u
keybind = super+digit_2=csi:50;3u
keybind = super+digit_3=csi:51;3u
keybind = super+digit_4=csi:52;3u

# Mouse
link-url = true