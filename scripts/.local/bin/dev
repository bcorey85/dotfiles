#!/bin/bash
# Launch a coding layout for a project.
# Usage: dev [directory]
#   If a directory is provided, all panes/windows open there; otherwise cwd.
#
# Layout:
#   Window 1 "code"     nvim (60%) | claude (40%). The claude pane is a plain
#                       companion, not a managed agent — stash/restore it with
#                       C-' (claude-companion) when you want the width back;
#                       the conversation survives. Background agents are
#                       workmux's job, and they stay out of this window.
#   Window 2 "console"  three equal shells for git / tests / logs. If the
#                       project has an mprocs config, pane 1 runs the service
#                       stack under mprocs instead of a bare shell — r restarts
#                       a proc, x stops it. Config lookup order:
#                         1. <project>/mprocs.yaml            (committable repos)
#                         2. ~/.config/mprocs/projects/<basename>.yaml
#                            (work repos where tooling files can't live in the
#                            tree; procs still run with the pane's cwd = project
#                            root, so relative commands work unchanged)

if [ -z "$TMUX" ]; then
    echo "Not in a tmux session"
    exit 1
fi

dir="${1:-.}"
dir="$(cd "$dir" && pwd)" || { echo "dev: no such directory: ${1:-.}" >&2; exit 1; }

# Window 1 "code": nvim (60%) | claude (40%).
# -p 40 sizes the NEW (right) pane to 40%, leaving nvim at 60%.
# Using -p instead of -l 40% for compatibility with older tmux (Ubuntu/WSL).
tmux rename-window "code"
tmux send-keys "nvim ." C-m
tmux split-window -h -p 40 -c "$dir"
tmux send-keys "claude" C-m
tmux select-pane -L          # land on the editor

# Window 2 "console": three equal shells side by side
tmux new-window -n "console" -c "$dir"
tmux split-window -h -c "$dir"
tmux split-window -h -c "$dir"
tmux select-layout even-horizontal
tmux select-pane -t 1        # focus the leftmost shell
mprocs_cfg=""
if [ -f "$dir/mprocs.yaml" ]; then
    mprocs_cfg="$dir/mprocs.yaml"
elif [ -f "$HOME/.config/mprocs/projects/$(basename "$dir").yaml" ]; then
    mprocs_cfg="$HOME/.config/mprocs/projects/$(basename "$dir").yaml"
fi
if [ -n "$mprocs_cfg" ] && command -v mprocs &>/dev/null; then
    tmux send-keys "mprocs --config \"$mprocs_cfg\"" C-m
fi

# Back to the code window, editor pane
tmux select-window -t 1
