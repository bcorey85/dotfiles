#!/bin/bash
# Show Hyprland keybindings via rofi, generated live from hyprctl binds -j.
# Requires: hyprctl, jq, rofi

{
    hyprctl binds -j | jq -r '
        .[]
        | select(.mouse == false)
        | .modmask as $mask
        | ( [64, 8, 4, 1]
            | map(select(($mask / . | floor) % 2 == 1))
            | map(if . == 64 then "SUPER" elif . == 1 then "SHIFT" elif . == 4 then "CTRL" elif . == 8 then "ALT" else "MOD\(.)" end)
            | join(" + ")
          ) as $mods
        | (if .has_description and .description != "" then .description
           else "\(.dispatcher)\(if .arg != "" then " \(.arg)" else "" end)"
           end) as $label
        | "\(if $mask == 0 then "" else $mods + " + " end)\(.key)|\($label)"
    ' | column -t -s '|'

    printf "\n"
    printf "SUPER + LMB drag  |  Move window\n"
    printf "SUPER + RMB drag  |  Resize window\n"
} | rofi -dmenu -i -p "Keybinds" -no-custom
