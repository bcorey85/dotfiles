#!/bin/bash
set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

print_success() { echo -e "${GREEN}✓${NC} $1"; }
print_error() { echo -e "${RED}✗${NC} $1"; }
print_info() { echo -e "${YELLOW}→${NC} $1"; }

# mise owns node when present (.zshrc skips nvm entirely), so a global node
# must exist before the next shell starts — otherwise gating nvm off would
# leave the machine with no node at all. Per-project versions still come
# from .nvmrc / .node-version / mise.toml.
if ! command -v mise &>/dev/null; then
  print_info "mise not installed — skipping (run install/deps first)"
  exit 0
fi

if mise which node &>/dev/null; then
  print_success "mise already manages node"
else
  print_info "Installing node LTS via mise..."
  mise use -g node@lts
  print_success "node LTS installed (mise global)"
fi
