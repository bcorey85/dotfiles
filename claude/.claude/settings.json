      "Bash(type *)",
      "Bash(uname *)",
      "Bash(date *)",
      "Bash(dirname *)",
      "Bash(basename *)",
      "Bash(realpath *)",
      "Bash(readlink *)",
      "Bash(whoami)",
      "Bash(id)",
      "Bash(hostname)",
      "Bash(tree *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(du *)",
      "Bash(df *)",
      "Bash(lsof *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(diff *)",
      "Bash(cut *)",
      "Bash(tr *)",
      "Bash(jq *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(sha256sum *)",
      "Bash(shasum *)",
      "Bash(md5sum *)",
      "Bash(printenv PATH)",
      "Bash(printenv HOME)",
      "Bash(printenv USER)",
      "Bash(printenv SHELL)",
      "Bash(printenv TERM)",
      "Bash(printenv LANG)",
      "Bash(printenv PWD)",
      "Bash(mkdir -p *)",
      "Bash(mkdir *)",
      "Bash(man *)",
      "Bash(ps *)",
      "Bash(node --version)",
      "Bash(node -v)",
      "Bash(node --help *)",
      "Bash(npm --version)",
      "Bash(npm list *)",
      "Bash(npm ls *)",
      "Bash(pnpm --version)",
      "Bash(pnpm list *)",
      "Bash(pnpm ls *)",
      "Bash(pnpm why *)",
      "Bash(python --version)",
      "Bash(python -V)",
      "Bash(python3 --version)",
      "Bash(python3 -V)",
      "Bash(pip --version)",
