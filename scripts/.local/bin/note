#!/bin/bash
# Frictionless capture: append a timestamped one-liner to today's inbox note.
# No structure on purpose — the nightly daily-recap compile classifies these
# into decisions/roadblocks/follow-ups. Capture is the human's job, structure
# is the machine's.
set -e

VAULT="${VAULT_DIR:-$HOME/vault}"
INBOX="$VAULT/Inbox"
FILE="$INBOX/$(date +%F).md"

if [ $# -eq 0 ]; then
  echo "usage: note <text>    e.g. note platform team blocked on auth schema" >&2
  echo "lanes: plain text | done: <text> retires a follow-up" >&2
  exit 1
fi

mkdir -p "$INBOX"
printf -- '- %s %s\n' "$(date +%H:%M)" "$*" >>"$FILE"
