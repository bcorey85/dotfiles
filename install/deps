#!/bin/bash
set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

print_success() { echo -e "${GREEN}✓${NC} $1"; }
print_error() { echo -e "${RED}✗${NC} $1"; }
print_info() { echo -e "${YELLOW}→${NC} $1"; }

# mprocs — service-stack runner for the `dev` console window (per-project
# mprocs.yaml). Upstream renamed the repo pvolok/mprocs -> pvolok/dekit, which
# broke the AUR `mprocs` PKGBUILD (its `cd mprocs-0.9.6` fails — the renamed
# source archive extracts to dekit-0.9.6/). The prebuilt release binary is
# unaffected (asset still named mprocs-*, a single top-level `mprocs` binary),
# so install it from GitHub on every Linux platform. Tags are v-prefixed, asset
# names are not. Used by wsl|ubuntu and arch below (mac uses brew).
install_mprocs() {
  if command -v mprocs &>/dev/null; then
    print_success "mprocs already installed"
    return
  fi
  print_info "Installing mprocs..."
  local ver url
  ver=$(curl -fsSL "https://api.github.com/repos/pvolok/dekit/releases/latest" | jq -r .tag_name)
  url="https://github.com/pvolok/dekit/releases/download/${ver}/mprocs-${ver#v}-linux-$(uname -m)-musl.tar.gz"
  mkdir -p ~/.local/bin
  curl -fLo /tmp/mprocs.tar.gz "$url"
  tar -xzf /tmp/mprocs.tar.gz -C /tmp
  cp /tmp/mprocs ~/.local/bin/
  chmod +x ~/.local/bin/mprocs
  rm -f /tmp/mprocs.tar.gz /tmp/mprocs
  print_success "mprocs installed"
}

PLATFORM=${1:-}

if [[ ! "$PLATFORM" =~ ^(wsl|ubuntu|mac|arch)$ ]]; then
  print_error "Usage: ./setup-deps [wsl|ubuntu|mac|arch]"
  exit 1
fi

case $PLATFORM in
wsl | ubuntu)
  print_info "Installing dependencies via apt..."
  sudo apt update
  sudo apt install -y stow neovim emacs tmux zsh git curl jq libnotify-bin fzf zoxide unzip direnv git-delta btop bat atuin eza glow fd-find ripgrep keychain rustup ansible just xclip wl-clipboard imagemagick tree-sitter-cli
  print_success "Dependencies installed"

  # Ubuntu installs bat as batcat and fd as fdfind — symlink to expected names
  mkdir -p ~/.local/bin
  command -v bat &>/dev/null || ln -sf "$(command -v batcat)" ~/.local/bin/bat
  command -v fd &>/dev/null || ln -sf "$(command -v fdfind)" ~/.local/bin/fd

  if ! command -v tldr &>/dev/null; then
    print_info "Installing tlrc..."
    TLRC_VER=$(curl -sI "https://github.com/tldr-pages/tlrc/releases/latest" | grep -i location | sed 's/.*tag\///' | tr -d '[:space:]')
    TLRC_URL="https://github.com/tldr-pages/tlrc/releases/latest/download/tlrc-${TLRC_VER}-$(uname -m)-unknown-linux-musl.tar.gz"
    mkdir -p ~/.local/bin
    curl -fLo /tmp/tlrc.tar.gz "$TLRC_URL"
    tar -xzf /tmp/tlrc.tar.gz -C /tmp
    cp /tmp/tldr ~/.local/bin/
    chmod +x ~/.local/bin/tldr
    rm -f /tmp/tlrc.tar.gz /tmp/tldr
    print_success "tlrc installed"
  else
    print_success "tlrc already installed"
  fi

  # mise — runtime version manager (replaces nvm; official repo via extrepo)
  if ! command -v mise &>/dev/null; then
    print_info "Installing mise..."
    sudo apt install -y extrepo
    sudo extrepo enable mise
    sudo apt update
    sudo apt install -y mise
    print_success "mise installed"
  else
    print_success "mise already installed"
  fi

  # gh — GitHub CLI (octo.nvim + gh-dash depend on it; official repo is
  # codename-neutral so one source file covers every Ubuntu/Debian release)
  if ! command -v gh &>/dev/null; then
    print_info "Installing gh..."
    sudo mkdir -p -m 755 /etc/apt/keyrings
    curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | sudo tee /etc/apt/keyrings/githubcli-archive-keyring.gpg >/dev/null
    sudo chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | sudo tee /etc/apt/sources.list.d/github-cli.list >/dev/null
    sudo apt update
    sudo apt install -y gh
    print_success "gh installed"
  else
    print_success "gh already installed"
  fi

  # lazydocker — docker dashboard TUI (tmux prefix l popup). Not packaged for
  # apt; GitHub release binary, same pattern as tlrc. Release tags are
  # v-prefixed but asset names are not, and assets say arm64, not aarch64.
  if ! command -v lazydocker &>/dev/null; then
    print_info "Installing lazydocker..."
    LD_ARCH=$(uname -m)
    [ "$LD_ARCH" = "aarch64" ] && LD_ARCH="arm64"
    LD_VER=$(curl -sI "https://github.com/jesseduffield/lazydocker/releases/latest" | grep -i location | sed 's/.*tag\///' | tr -d '[:space:]')
    LD_URL="https://github.com/jesseduffield/lazydocker/releases/latest/download/lazydocker_${LD_VER#v}_Linux_${LD_ARCH}.tar.gz"
    mkdir -p ~/.local/bin
    curl -fLo /tmp/lazydocker.tar.gz "$LD_URL"
    tar -xzf /tmp/lazydocker.tar.gz -C /tmp lazydocker
    cp /tmp/lazydocker ~/.local/bin/
    chmod +x ~/.local/bin/lazydocker
    rm -f /tmp/lazydocker.tar.gz /tmp/lazydocker
    print_success "lazydocker installed"
  else
    print_success "lazydocker already installed"
  fi

  install_mprocs

  ;;
arch)
  print_info "Installing dependencies via pacman..."
  # inetutils: provides `hostname`, which tmux-resurrect's helpers call
  sudo pacman -S --needed stow neovim emacs tmux zsh git curl jq libnotify fzf zoxide unzip direnv ghostty git-delta btop bat atuin eza glow fd keychain rustup playerctl xdg-user-dirs ripgrep brightnessctl base-devel bluez bluez-utils less ansible just rsync xclip imagemagick inetutils mise github-cli lazydocker tree-sitter-cli
  print_success "Dependencies installed"

  # Hyprland desktop packages
  print_info "Installing Hyprland desktop packages..."
  sudo pacman -S --needed hyprland hyprlock hypridle hyprsunset hyprpicker waybar rofi dunst swww xdg-desktop-portal-hyprland xdg-desktop-portal-gtk polkit-gnome wl-clipboard cliphist grim slurp pavucontrol thunar tumbler thunar-archive-plugin file-roller gvfs gvfs-mtp udisks2 pipewire-alsa qt5ct qt6ct gsimplecal batsignal blueman
  print_success "Hyprland desktop packages installed"

  # Install paru (AUR helper)
  if ! command -v paru &>/dev/null; then
    print_info "Installing paru..."
    git clone https://aur.archlinux.org/paru.git /tmp/paru
    (cd /tmp/paru && makepkg -si --noconfirm)
    rm -rf /tmp/paru
    print_success "paru installed"
  else
    print_success "paru already installed"
  fi

  # AUR packages. mprocs is intentionally NOT here — its AUR PKGBUILD broke on
  # the upstream pvolok/mprocs -> pvolok/dekit rename; it's installed from the
  # release binary via install_mprocs below. `|| print_error` keeps a single
  # failed/flaky AUR build (set -e is on) from aborting the rest of setup.
  if command -v paru &>/dev/null; then
    print_info "Installing AUR packages via paru..."
    paru -S --needed discord_arch_electron google-chrome plexamp-bin revdiff ||
      print_error "some AUR packages failed to build — continuing"
    print_success "AUR packages installed"
  else
    print_error "paru not found — skipping AUR packages"
  fi

  install_mprocs

  if ! command -v tldr &>/dev/null; then
    print_info "Installing tlrc..."
    TLRC_VER=$(curl -sI "https://github.com/tldr-pages/tlrc/releases/latest" | grep -i location | sed 's/.*tag\///' | tr -d '[:space:]')
    TLRC_URL="https://github.com/tldr-pages/tlrc/releases/latest/download/tlrc-${TLRC_VER}-$(uname -m)-unknown-linux-musl.tar.gz"
    mkdir -p ~/.local/bin
    curl -fLo /tmp/tlrc.tar.gz "$TLRC_URL"
    tar -xzf /tmp/tlrc.tar.gz -C /tmp
    cp /tmp/tldr ~/.local/bin/
    chmod +x ~/.local/bin/tldr
    rm -f /tmp/tlrc.tar.gz /tmp/tldr
    print_success "tlrc installed"
  else
    print_success "tlrc already installed"
  fi
  ;;
mac)
  print_info "Checking for Homebrew..."
  if ! command -v brew &>/dev/null; then
    print_info "Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    print_success "Homebrew installed"
  else
    print_success "Homebrew already installed"
  fi

  print_info "Installing dependencies via Homebrew..."
  brew install stow neovim emacs tmux git jq fzf zoxide direnv git-delta btop bat atuin eza tlrc glow fd ripgrep keychain rustup ansible just imagemagick kanata mise gh mprocs lazydocker tree-sitter-cli
  brew install umputun/apps/revdiff
  brew install --cask nikitabobko/tap/aerospace
  print_success "Dependencies installed"
  ;;
esac
